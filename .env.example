# Example environment variables for local development
# Replace values with your own credentials. DO NOT commit real secrets.

# Local Postgres example:
DATABASE_URL=postgresql://postgres:password@localhost:5432/sophymusic

# Neon example (uncomment and replace SECRET and host):
# DATABASE_URL=postgresql://neondb_owner:SECRET@ep-xxxxxx.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Optional admin credentials used by the seed script
# ADMIN_EMAIL=admin@sophymusic.com
# ADMIN_PASSWORD=admin123
# ─── Database (Neon) ─────────────────────────────────────────────
# Pooled connection - usada por Prisma en runtime (serverless)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/sophymusic?sslmode=require&pgbouncer=true
# Direct connection - usada por Prisma Migrate / seed
DATABASE_URL_UNPOOLED=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/sophymusic?sslmode=require

# ─── Authentication ───────────────────────────────────────────────
JWT_SECRET=reemplazar-por-string-aleatorio-de-minimo-32-caracteres

# ─── Email (Gmail OAuth2) ─────────────────────────────────────
GMAIL_USER=tu-cuenta@gmail.com
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
GOOGLE_REFRESH_TOKEN=1//xxxx
CONTACT_RECIPIENT=tu-cuenta@gmail.com

# ─── Cloudflare R2 (file uploads) ────────────────────────────────
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=tu-r2-access-key
R2_SECRET_ACCESS_KEY=tu-r2-secret-key
R2_BUCKET_NAME=sophy-music-uploads
# URL pública del bucket (dominio personalizado o URL pública de R2)
R2_PUBLIC_URL=https://uploads.tudominio.com
