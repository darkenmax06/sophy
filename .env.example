# ─── Database (Neon) ─────────────────────────────────────────────
# Pooled connection - usada por Prisma en runtime (serverless)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/sophymusic?sslmode=require&pgbouncer=true
# Direct connection - usada por Prisma Migrate / seed
DATABASE_URL_UNPOOLED=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/sophymusic?sslmode=require

# ─── Authentication ───────────────────────────────────────────────
JWT_SECRET=reemplazar-por-string-aleatorio-de-minimo-32-caracteres

# ─── Email (SMTP) ─────────────────────────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=tu-email@tudominio.com
SMTP_PASS=tu-contraseña-smtp

# ─── Cloudflare R2 (file uploads) ────────────────────────────────
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=tu-r2-access-key
R2_SECRET_ACCESS_KEY=tu-r2-secret-key
R2_BUCKET_NAME=sophy-music-uploads
# URL pública del bucket (dominio personalizado o URL pública de R2)
R2_PUBLIC_URL=https://uploads.tudominio.com
