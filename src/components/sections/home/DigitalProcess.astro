---
interface Props {
  t: any;
  lang: string;
}
const { t, lang } = Astro.props;
const idx = t.index;

const steps = [
  { icon: "digital-marketing-icons-N952ZWA.png", key: "strategy1", num: "01", animDir: "animate__fadeInUp" },
  { icon: "Icon-11.png", key: "strategy2", num: "02", animDir: "animate__fadeInDown", hasSpacer: true },
  { icon: "Icon-10.png", key: "strategy3", num: "03", animDir: "animate__fadeInUp", hasSpacer: true },
  { icon: "Icon-12.png", key: "strategy4", num: "04", animDir: "animate__fadeInDown", hasSpacer: true },
];
---
<div class="section-wrapper-digital-process">
    <div class="section digital-process-banner">
        <div class="hero-container">
            <div class="digital-process-content">
                <div class="row row-cols-xl-2 row-cols-1 grid-spacer-5">
                    <div class="col">
                        <div class="d-flex flex-column gspace-2 animate-box animated animate__animated" data-animate="animate__fadeInDown">
                            <div class="sub-heading">
                                <i class="fa-regular fa-circle-dot"></i>
                                <span>{idx.work_title}</span>
                            </div>
                            <h2 class="title-heading">{idx.work_sub_title}</h2>
                        </div>
                    </div>
                    <div class="col">
                        <div class="d-flex flex-column gspace-2 justify-content-end h-100 animate-box animated fast animate__animated" data-animate="animate__fadeInDown">
                            <p>{idx.work_text}</p>
                            <div class="link-wrapper">
                                <a href={`/${lang}/contact`}>{idx.work_button}</a>
                                <i class="fa-solid fa-arrow-circle-right"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="digital-process-steps-wrapper">
                    <div class="digital-process-steps">
                        <div class="row row-cols-xl-4 row-cols-md-2 row-cols-1">
                            {steps.map((step) => (
                                <div class="col">
                                    {step.hasSpacer ? (
                                        <div class={`d-flex flex-md-row flex-column gspace-2 animate-box animated animate__animated`} data-animate={step.animDir}>
                                            <div class="step-spacer"></div>
                                            <div class="digital-process-step">
                                                <div class="d-flex justify-content-between">
                                                    <div>
                                                        <img src={`/image/${step.icon}`} alt="Digital Process Icon" class="process-icon">
                                                    </div>
                                                    <span>{step.num}</span>
                                                </div>
                                                <div class="d-flex flex-column gspace-2">
                                                    <h5>{(idx as any)[step.key]}</h5>
                                                </div>
                                            </div>
                                        </div>
                                    ) : (
                                        <div class="digital-process-step animate-box animated animate__animated" data-animate={step.animDir}>
                                            <div class="d-flex justify-content-between">
                                                <div>
                                                    <img src={`/image/${step.icon}`} alt="Digital Proccess Icon" class="process-icon">
                                                </div>
                                                <span>{step.num}</span>
                                            </div>
                                            <div class="d-flex flex-column gspace-2">
                                                <h5>{(idx as any)[step.key]}</h5>
                                            </div>
                                        </div>
                                    )}
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="spacer"></div>
</div>
