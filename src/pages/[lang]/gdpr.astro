---
export const prerender = true;

import LegalLayout from '../../layouts/LegalLayout.astro';
import { getTranslations, locales, type Locale } from '../../i18n';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = getTranslations(lang);
const g = t.gdpr;
---
<LegalLayout
  lang={lang}
  title={g['gdpr.page_title']}
  dataPage="gdpr"
  bannerTitle={g['gdpr.banner_title']}
  breadcrumbHome={g['gdpr.breadcrumb_home']}
  breadcrumbCurrent={g['gdpr.breadcrumb_current']}
>
    <section class="gdpr">
        <div class="gdpr__container">
            <h1 class="gdpr__title">{g['gdpr.main_title']}</h1>
            <p class="gdpr__text">{g['gdpr.intro_text']}</p>

            {[1,2,3,4].map((n) => (
                <div class="gdpr__block">
                    <h2 class="gdpr__subtitle">{(g as any)[`gdpr.section${n}_title`]}</h2>
                    <p class="gdpr__text">{(g as any)[`gdpr.section${n}_text`]}</p>
                </div>
            ))}
        </div>
    </section>
</LegalLayout>
