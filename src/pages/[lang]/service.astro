---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations, locales, type Locale } from '../../i18n';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = getTranslations(lang);
const sv = t.service;
const idx = t.index;

const cards = [
  { icon: "Icon-7.png", titleKey: "specialties_card1_title", textKey: "specialties_card1_text", speed: "slow" },
  { icon: "digital-marketing-icons-F4LJ4W8.png", titleKey: "specialties_card2_title", textKey: "specialties_card2_text", speed: "" },
  { icon: "Icon-8.png", titleKey: "specialties_card3_title", textKey: "specialties_card3_text", speed: "fast" },
  { icon: "Icon-5.png", titleKey: "specialties_card4_title", textKey: "specialties_card4_text", speed: "slow" },
  { icon: "Icon-6.png", titleKey: "specialties_card5_title", textKey: "specialties_card5_text", speed: "" },
  { icon: "Icon-4.png", titleKey: "specialties_card6_title", textKey: "specialties_card6_text", speed: "fast" },
];
---
<BaseLayout lang={lang} title={sv.banner_title} dataPage="service">
    <!-- Section Banner -->
    <div class="section-banner">
        <div class="banner-layout-wrapper">
            <div class="banner-layout">
                <div class="d-flex flex-column text-center align-items-center gspace-2">
                    <h2 class="title-heading animate-box animated animate__animated" data-animate="animate__fadeInRight">{sv.banner_title}</h2>
                    <nav class="breadcrumb">
                        <a href={`/${lang}`} class="gspace-2">{sv.breadcrumb_home}</a>
                        <span class="separator-link">/</span>
                        <p class="current-page">{sv.breadcrumb_current}</p>
                    </nav>
                </div>
                <div class="spacer"></div>
            </div>
        </div>
    </div>

    <!-- Section Intro -->
    <div class="section">
        <div class="hero-container">
            <div class="d-flex flex-column justify-content-center text-center gspace-2">
                <div class="sub-heading align-self-center animate-box animated animate__animated" data-animate="animate__fadeInDown">
                    <i class="fa-regular fa-circle-dot"></i>
                    <span>{sv.specialties_heading}</span>
                </div>
                <h2 class="title-heading heading-container heading-container-medium animate-box animated animate__animated" data-animate="animate__fadeInDown">{sv.main_title}</h2>
                <p class="heading-container heading-container-medium">{sv.intro}</p>
            </div>
        </div>
    </div>

    <!-- Section Specialties -->
    <div class="section">
        <div class="hero-container">
            <div class="d-flex flex-column justify-content-center text-center gspace-5">
                <div class="d-flex flex-column justify-content-center text-center gspace-2">
                    <div class="sub-heading align-self-center animate-box animated animate__animated" data-animate="animate__fadeInDown">
                        <i class="fa-regular fa-circle-dot"></i>
                        <span>{sv.specialties_sub}</span>
                    </div>
                </div>
                <div class="card-service-wrapper">
                    <div class="row row-cols-xl-3 row-cols-md-2 row-cols-1 grid-spacer-2">
                        {cards.map((card) => (
                            <div class="col">
                                <div class={`card card-service animate-box animated ${card.speed} animate__animated`} data-animate="animate__fadeInLeft">
                                    <div class="d-flex flex-row justify-content-between gspace-2 gspace-md-3 align-items-center">
                                        <div>
                                            <div class="service-icon-wrapper">
                                                <div class="service-icon">
                                                    <img src={`/image/${card.icon}`} alt="Service Icon" class="img-fluid">
                                                </div>
                                            </div>
                                        </div>
                                        <div class="service-title">
                                            <h4>{(idx as any)[card.titleKey]}</h4>
                                        </div>
                                    </div>
                                    <p>{(idx as any)[card.textKey]}</p>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Section Pricing Plans -->
    <div class="section" id="servicios">
        <div class="hero-container">
            <div class="d-flex flex-column justify-content-center text-center gspace-5">
                <div class="d-flex flex-column gspace-2 animate-box animated animate__animated" data-animate="animate__fadeInUp">
                    <div class="sub-heading align-self-center">
                        <i class="fa-regular fa-circle-dot"></i>
                        <span>{sv.plans_title}</span>
                    </div>
                    <h2 class="title-heading heading-container heading-container-short">{sv.plans_subtitle}</h2>
                </div>
                <div class="row row-cols-xl-3 row-cols-1 grid-spacer-2">
                    <!-- Column 1: Solo Sound -->
                    <div class="col">
                        <div class="pricing-container">
                            <div class="w-100 d-gri card card-pricing-title animate-box animated animate__animated" data-animate="animate__fadeInLeft">
                                <div class="spacer"></div>
                                <div class="content">
                                    <h3 class="title-heading fa-2x">{idx.services_card1_title}</h3>
                                    <div class="link-wrapper">
                                        <a href={`/${lang}/contact`}>{idx.services_card1_button}</a>
                                        <i class="fa-solid fa-arrow-circle-right"></i>
                                    </div>
                                </div>
                            </div>
                            <div class="card card-pricing animate-box animated animate__animated" data-animate="animate__fadeInUp">
                                <h4>{idx.plan1_title}</h4>
                                <p>{idx.plan1_description}</p>
                                <div class="d-flex flex-row gspace-1 align-items-center h-100">
                                    <h3>$20</h3>
                                    <p>{idx.plan1_year}</p>
                                </div>
                                <a href={`/${lang}/contact`} class="btn btn-accent">
                                    <div class="btn-title">
                                        <span>{idx.plan1_button}</span>
                                    </div>
                                    <div class="icon-circle">
                                        <i class="fa-solid fa-arrow-right"></i>
                                    </div>
                                </a>
                                <ul class="check-list">
                                    <li><a href={`/${lang}/solo-sound`}>{idx.plan1_el1}</a></li>
                                    <li><a href={`/${lang}/solo-sound`}>{idx.plan1_el2}</a></li>
                                    <li><a href={`/${lang}/solo-sound`}>{idx.plan1_el3}</a></li>
                                </ul>
                                <div class="link-wrapper align-self-center">
                                    <a href={`/${lang}/solo-sound`}>{idx.services_card1_view_more}</a>
                                    <i class="fa-solid fa-arrow-circle-right"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Column 2: Label Epic (highlighted) -->
                    <div class="col">
                        <div class="card card-pricing pricing-highlight animate-box animated slow animate__animated" data-animate="animate__fadeInUp">
                            <div class="spacer"></div>
                            <h4>{idx.plan2_title}</h4>
                            <p>{idx.plan2_description}</p>
                            <div class="d-flex flex-row gspace-1 align-items-center">
                                <h3>$50</h3>
                                <p>{idx.plan2_year}</p>
                            </div>
                            <a href={`/${lang}/contact`} class="btn btn-accent">
                                <div class="btn-title">
                                    <span>{idx.plan2_button}</span>
                                </div>
                                <div class="icon-circle">
                                    <i class="fa-solid fa-arrow-right"></i>
                                </div>
                            </a>
                            <div class="core-benefits">
                                <div class="benefit">
                                    <strong>{idx.plan2_el1}</strong>
                                </div>
                                <div class="benefit">
                                    <strong>{idx.plan2_el2}</strong>
                                </div>
                                <div class="benefit">
                                    <strong>{idx.plan2_el3}</strong>
                                </div>
                            </div>
                            <ul class="check-list">
                                <li><strong>{idx.plan2_el4}</strong></li>
                                <li><strong>{idx.plan2_el5}</strong></li>
                                <li><strong>{idx.plan2_el6}</strong></li>
                                <li><strong>{idx.plan2_el7}</strong></li>
                                <li><strong>{idx.plan2_el8}</strong></li>
                                <li><strong>{idx.plan2_el9}</strong></li>
                            </ul>
                            <div class="link-wrapper align-self-center">
                                <a href={`/${lang}/label-epic`}>{idx.services_card1_view_more}</a>
                                <i class="fa-solid fa-arrow-circle-right"></i>
                            </div>
                        </div>
                    </div>
                    <!-- Column 3: Colaborador -->
                    <div class="col">
                        <div class="pricing-container">
                            <div class="card pricing-highlight-box animate-box animated animate__animated" data-animate="animate__fadeInRight">
                                <div class="d-flex flex-column gspace-2 w-100">
                                    <h5>{idx.services_card2_title}</h5>
                                    <div class="d-flex flex-column gspace-2">
                                        <div class="pricing-highlights">
                                            <strong>{idx.services_card2_el1}</strong>
                                            <i class="fa-solid fa-arrow-circle-right"></i>
                                        </div>
                                        <div class="pricing-highlights">
                                            <strong style="text-align: start;">{idx.services_card2_el2}</strong>
                                            <i class="fa-solid fa-arrow-circle-right"></i>
                                        </div>
                                        <div class="pricing-highlights">
                                            <strong>{idx.services_card2_el3}</strong>
                                            <i class="fa-solid fa-arrow-circle-right"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="spacer"></div>
                            </div>
                            <div class="card card-pricing animate-box animated animate__animated" data-animate="animate__fadeInUp">
                                <h4>{idx.plan3_title}</h4>
                                <p>{idx.plan3_description}</p>
                                <div class="d-flex flex-row gspace-1 align-items-center h-100">
                                    <h3>{idx.plan3_price}</h3>
                                    <p>{idx.plan3_year}</p>
                                </div>
                                <a href={`/${lang}/contact`} class="btn btn-accent">
                                    <div class="btn-title">
                                        <span>{idx.plan3_button}</span>
                                    </div>
                                    <div class="icon-circle">
                                        <i class="fa-solid fa-arrow-right"></i>
                                    </div>
                                </a>
                                <ul class="check-list">
                                    <li><a href={`/${lang}/two-fusion`}>{idx.plan3_el1}</a></li>
                                    <li><a href={`/${lang}/two-fusion`}>{idx.plan3_el2}</a></li>
                                    <li><a href={`/${lang}/two-fusion`}>{idx.plan3_el3}</a></li>
                                </ul>
                                <div class="link-wrapper align-self-center">
                                    <a href={`/${lang}/two-fusion`}>{idx.services_card1_view_more}</a>
                                    <i class="fa-solid fa-arrow-circle-right"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- CTA Section -->
    <div class="section">
        <div class="hero-container">
            <div class="card card-guide animate-box animated animate__animated" data-animate="animate__fadeInUp">
                <div class="card-guide-content">
                    <h3>{sv.cta_title}</h3>
                    <p>{sv.cta_text}</p>
                    <a href={`/${lang}/contact`} class="btn btn-accent">
                        <div class="btn-title">
                            <span>{sv.cta_button}</span>
                        </div>
                        <div class="icon-circle">
                            <i class="fa-solid fa-arrow-right"></i>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script>
        import '../../scripts/scroll-animations';
        import '../../scripts/theme-toggle';
        import '../../scripts/sidebar-menu';
    </script>
</BaseLayout>
