---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations, locales, type Locale } from '../../i18n';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = getTranslations(lang);
const s = t.solo;
---
<BaseLayout lang={lang} title={s.solo_sound} dataPage="solo">
    <!-- Section Banner -->
    <div class="section-banner">
        <div class="banner-layout-wrapper">
            <div class="banner-layout">
                <div class="d-flex flex-column text-center align-items-center gspace-2">
                    <h2 class="title-heading animate-box animated animate__animated" data-animate="animate__fadeInRight">{s.solo_sound}</h2>
                    <nav class="breadcrumb">
                        <a href={`/${lang}`} class="gspace-2">{s.inicio}</a>
                        <span class="separator-link">/</span>
                        <p class="current-page">{s.solo_sound}</p>
                    </nav>
                </div>
                <div class="spacer"></div>
            </div>
        </div>
    </div>

    <!-- Section Services -->
    <div class="section pb-20">
        <div class="hero-container">
            <div class="d-flex flex-column gspace-5">
                <div class="image-container">
                    <img src="/image/le1 (2).jpg" alt="Service Image" class="single-service-img">
                    <div class="single-service-title-layout">
                        <div class="">
                            <div class="single-service-spacer"></div>
                            <div class="single-service-title-wrapper">
                                <div class="single-service-title">
                                    <div class="sub-heading animate-box animated slow animate__animated" data-animate="animate__fadeInRight">
                                        <i class="fa-regular fa-circle-dot"></i>
                                        <span>{s.solo_sound}</span>
                                    </div>
                                    <h3 class="title-heading animate-box animated animate__animated" data-animate="animate__fadeInRight">{s.ideal_para_artistas}</h3>
                                    <p>{s.descripcion_larga}</p>
                                </div>
                            </div>
                        </div>
                        <div class="single-service-spacer"></div>
                    </div>
                </div>

                <div class="row row-cols-xl-2 row-cols-1 grid-spacer-5">
                    <div class="col col-xl-8">
                        <div class="d-flex flex-column gspace-2">
                            <h4>{s.descripcion_breve_titulo}</h4>
                            <p>{s.descripcion_breve_texto}</p>

                            <div class="row row-cols-md-2 row-cols-1 grid-spacer-2 grid-spacer-md-3">
                                <div class="col">
                                    <div class="image-container">
                                        <img src="/image/ss2.jpg" alt="Service Image" class="img-fluid">
                                    </div>
                                </div>
                                <div class="col">
                                    <div class="image-container">
                                        <img src="/image/solosound.jpg" alt="Service Image" class="img-fluid">
                                    </div>
                                </div>
                            </div>

                            <div class="card service-included">
                                <h4>{s.que_incluye}</h4>
                                <div class="underline-accent-short"></div>
                                <p>{s.que_incluye_descripcion}</p>
                                <div class="row row-cols-md-2 row-cols-1 grid-spacer-2">
                                    <div class="col">
                                        <ul class="check-list">
                                            <li>{s.incluye_1}</li>
                                            <li>{s.incluye_2}</li>
                                            <li>{s.incluye_3}</li>
                                            <li>{s.incluye_4}</li>
                                        </ul>
                                    </div>
                                    <div class="col">
                                        <ul class="check-list">
                                            <li>{s.incluye_5}</li>
                                            <li>{s.incluye_6}</li>
                                            <li>{s.incluye_7}</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>

                            <h4>{s.porque_elegir}</h4>
                            <p>{s.porque_elegir_texto}</p>

                            <div class="row row-cols-2">
                                <div class="col">
                                    <div class="d-flex flex-column gspace-2">
                                        <div class="d-flex flex-column flex-md-row align-items-center text-center text-md-start gspace-1">
                                            <i class="fa-regular fa-2x fa-circle-check accent-color"></i>
                                            <div class="d-flex flex-column gspace-0">
                                                <p>{s.beneficio_1}</p>
                                            </div>
                                        </div>
                                        <div class="d-flex flex-column flex-md-row align-items-center text-center text-md-start gspace-1">
                                            <i class="fa-regular fa-2x fa-circle-check accent-color"></i>
                                            <div class="d-flex flex-column gspace-0">
                                                <p>{s.beneficio_2}</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col">
                                    <div class="d-flex flex-column gspace-2">
                                        <div class="d-flex flex-column flex-md-row align-items-center text-center text-md-start gspace-1">
                                            <i class="fa-regular fa-2x fa-circle-check accent-color"></i>
                                            <div class="d-flex flex-column gspace-0">
                                                <p>{s.beneficio_3}</p>
                                            </div>
                                        </div>
                                        <div class="d-flex flex-column flex-md-row align-items-center text-center text-md-start gspace-1">
                                            <i class="fa-regular fa-2x fa-circle-check accent-color"></i>
                                            <div class="d-flex flex-column gspace-0">
                                                <p>{s.beneficio_4}</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col col-xl-4">
                        <div class="d-flex flex-column flex-md-row flex-xl-column justify-content-between gspace-5">
                            <div class="cta-service-banner">
                                <div class="spacer"></div>
                                <h3 class="title-heading">{s.rompe_barreras}</h3>
                                <p>{s.solicita_descripcion}</p>
                                <div class="link-wrapper">
                                    <a href={`/${lang}/contact`}>{s.solicitar}</a>
                                    <i class="fa-solid fa-circle-arrow-right"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        import '../../scripts/scroll-animations';
        import '../../scripts/theme-toggle';
        import '../../scripts/sidebar-menu';
    </script>
</BaseLayout>
