---
import AdminLayout from '../../layouts/AdminLayout.astro';
import prisma from '../../lib/prisma';
import { isAuthenticated } from '../../lib/auth';

const user = isAuthenticated(Astro.request);
if (!user) return Astro.redirect('/admin/login');

const categories = await prisma.blogCategory.findMany({
  include: {
    translations: true,
    _count: { select: { posts: true } },
  },
  orderBy: { slug: 'asc' },
});
---
<AdminLayout title="Categorías" activeTab="categories">
  <div class="page-header">
    <h1>Categorías</h1>
    <button class="btn btn-primary" onclick="showCreateForm()">
      <i class="fa-solid fa-plus"></i> Nueva Categoría
    </button>
  </div>

  <!-- Create Form (hidden by default) -->
  <div id="create-form" class="chart-container" style="display: none; margin-bottom: 24px;">
    <h3>Nueva Categoría</h3>
    <div class="form-group">
      <label>Slug</label>
      <input type="text" class="form-input" id="cat-slug" placeholder="mi-categoria" />
    </div>
    <div class="cat-grid">
      <div class="form-group">
        <label>Nombre (Español)</label>
        <input type="text" class="form-input" id="cat-es" placeholder="Mi Categoría" />
      </div>
      <div class="form-group">
        <label>Name (English)</label>
        <input type="text" class="form-input" id="cat-en" placeholder="My Category" />
      </div>
      <div class="form-group">
        <label>Nom (Français)</label>
        <input type="text" class="form-input" id="cat-fr" placeholder="Ma Catégorie" />
      </div>
      <div class="form-group">
        <label>Nome (Português)</label>
        <input type="text" class="form-input" id="cat-pt" placeholder="Minha Categoria" />
      </div>
    </div>
    <div class="header-actions">
      <button class="btn btn-primary" onclick="createCategory()">Crear</button>
      <button class="btn btn-secondary" onclick="hideCreateForm()">Cancelar</button>
    </div>
  </div>

  <div class="admin-table-container">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Slug</th>
          <th>ES</th>
          <th class="hide-mobile">EN</th>
          <th class="hide-mobile">FR</th>
          <th class="hide-mobile">PT</th>
          <th>Posts</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        {categories.map((cat) => {
          const getName = (lang: string) => cat.translations.find(t => t.lang === lang)?.name || '-';
          return (
            <tr>
              <td style="font-size: 12px; color: var(--text-color);">{cat.slug}</td>
              <td>{getName('es')}</td>
              <td class="hide-mobile">{getName('en')}</td>
              <td class="hide-mobile">{getName('fr')}</td>
              <td class="hide-mobile">{getName('pt')}</td>
              <td><span class="badge badge-success">{cat._count.posts}</span></td>
              <td>
                <button class="btn btn-danger btn-sm" onclick={`deleteCategory('${cat.id}')`} title="Eliminar">
                  <i class="fa-solid fa-trash"></i>
                </button>
              </td>
            </tr>
          );
        })}
        {categories.length === 0 && (
          <tr>
            <td colspan="7" style="text-align: center; padding: 40px; color: var(--text-color);">
              No hay categorías creadas
            </td>
          </tr>
        )}
      </tbody>
    </table>
  </div>

  <script is:inline>
    function showCreateForm() { document.getElementById('create-form').style.display = 'block'; }
    function hideCreateForm() { document.getElementById('create-form').style.display = 'none'; }

    async function createCategory() {
      const slug = document.getElementById('cat-slug').value.trim();
      if (!slug) { showToast('Slug requerido', 'error'); return; }

      const translations = [];
      for (const lang of ['es', 'en', 'fr', 'pt']) {
        const name = document.getElementById('cat-' + lang).value.trim();
        if (name) translations.push({ lang, name });
      }

      if (translations.length === 0) { showToast('Al menos un nombre requerido', 'error'); return; }

      try {
        await apiCall('/api/blog/categories', 'POST', { slug, translations });
        showToast('Categoría creada');
        setTimeout(() => window.location.reload(), 500);
      } catch (e) { /* handled */ }
    }

    async function deleteCategory(id) {
      if (!confirm('¿Eliminar esta categoría?')) return;
      try {
        const res = await fetch('/api/blog/categories', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
        if (res.ok) { showToast('Categoría eliminada'); setTimeout(() => window.location.reload(), 500); }
        else showToast('Error al eliminar', 'error');
      } catch { showToast('Error', 'error'); }
    }
  </script>
</AdminLayout>
