---
// Admin login page - no auth required
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login - Sophy Music</title>
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .admin-login-wrapper {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: var(--secondary, #040404);
      padding: 20px;
    }
    .admin-login-box {
      background: var(--accent-color-4, #0E0E0E);
      border: 1px solid var(--accent-color-3, #1F1F1F);
      border-radius: var(--global-border-radius, 25px);
      padding: 48px 40px;
      max-width: 420px;
      width: 100%;
      position: relative;
      overflow: hidden;
    }
    .admin-login-box::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, transparent, var(--accent-color, #C82AEF), transparent);
    }
    .admin-login-box h2 {
      color: var(--accent-color-2, #FFFFFF);
      margin-bottom: 8px;
      font-size: var(--font-size-3xl, 24px);
      font-weight: var(--font-weight-bold, 700);
    }
    .admin-login-box p {
      color: var(--text-color, #8B8B8B);
      margin-bottom: 28px;
    }
    .admin-login-box .form-group {
      margin-bottom: 20px;
    }
    .admin-login-box label {
      display: block;
      color: var(--primary, #D1D1D1);
      margin-bottom: 8px;
      font-size: 14px;
      font-weight: var(--font-weight-medium, 500);
    }
    .admin-login-box input {
      width: 100%;
      padding: 14px 18px;
      border: 1px solid var(--accent-color-3, #1F1F1F);
      border-radius: 100px;
      background: var(--secondary, #040404);
      color: var(--primary, #D1D1D1);
      font-size: 14px;
      box-sizing: border-box;
      font-family: 'Plus Jakarta Sans', sans-serif;
      transition: border-color 0.3s, box-shadow 0.3s;
    }
    .admin-login-box input:focus {
      outline: none;
      border-color: var(--accent-color, #C82AEF);
      box-shadow: 0 0 0 3px rgba(200, 42, 239, 0.1);
    }
    .admin-login-box input::placeholder {
      color: var(--text-color, #8B8B8B);
    }
    .admin-login-box .btn-login {
      width: 100%;
      padding: 14px;
      background: var(--accent-color, #C82AEF);
      color: #fff;
      border: none;
      border-radius: 100px;
      font-size: 16px;
      font-weight: var(--font-weight-semibold, 600);
      cursor: pointer;
      transition: all 0.3s;
      font-family: 'Plus Jakarta Sans', sans-serif;
      box-shadow: 0 2px 16px rgba(200, 42, 239, 0.3);
    }
    .admin-login-box .btn-login:hover {
      box-shadow: 0 4px 24px rgba(200, 42, 239, 0.45);
      transform: translateY(-1px);
    }
    .admin-login-box .error-msg {
      color: var(--error-color, #e63946);
      font-size: 14px;
      margin-top: 16px;
      display: none;
      text-align: center;
    }
    .admin-login-box .logo-container {
      text-align: center;
      margin-bottom: 24px;
    }
    .admin-login-box .logo-container img {
      max-width: 160px;
    }
    @media (max-width: 480px) {
      .admin-login-box {
        padding: 32px 24px;
        border-radius: 20px;
      }
      .admin-login-box h2 { font-size: 20px; }
      .admin-login-box input { padding: 12px 16px; }
      .admin-login-box .btn-login { padding: 12px; font-size: 15px; }
    }
  </style>
</head>
<body>
  <div class="admin-login-wrapper">
    <div class="admin-login-box">
      <div class="logo-container">
        <img src="/image/logo.png" alt="Sophy Music">
      </div>
      <h2>Panel de Administración</h2>
      <p>Inicia sesión para gestionar el blog</p>
      <form id="login-form">
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required placeholder="admin@sophymusic.com">
        </div>
        <div class="form-group">
          <label for="password">Contraseña</label>
          <input type="password" id="password" name="password" required placeholder="••••••••">
        </div>
        <button type="submit" class="btn-login">Iniciar Sesión</button>
        <p id="error-msg" class="error-msg"></p>
      </form>
    </div>
  </div>

  <script is:inline>
    document.getElementById('login-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = document.getElementById('email').value;
      const password = document.getElementById('password').value;
      const errorMsg = document.getElementById('error-msg');
      
      try {
        const res = await fetch('/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password }),
        });
        const data = await res.json();
        if (res.ok) {
          window.location.href = '/admin/dashboard';
        } else {
          errorMsg.textContent = data.error || 'Error al iniciar sesión';
          errorMsg.style.display = 'block';
        }
      } catch {
        errorMsg.textContent = 'Error de conexión';
        errorMsg.style.display = 'block';
      }
    });
  </script>
</body>
</html>
