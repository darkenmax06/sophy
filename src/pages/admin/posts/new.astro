---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import prisma from '../../../lib/prisma';
import { isAuthenticated } from '../../../lib/auth';

const user = isAuthenticated(Astro.request);
if (!user) return Astro.redirect('/admin/login');

const categories = await prisma.blogCategory.findMany({
  include: { translations: true },
  orderBy: { slug: 'asc' },
});

const langs = [
  { code: 'es', label: 'Español' },
  { code: 'en', label: 'English' },
  { code: 'fr', label: 'Français' },
  { code: 'pt', label: 'Português' },
];
---
<AdminLayout title="Nuevo Post" activeTab="new-post">
  <div class="page-header">
    <h1>Nuevo Post</h1>
    <div class="header-actions">
      <button class="btn btn-secondary" onclick="saveDraft()">
        <i class="fa-solid fa-floppy-disk"></i> Guardar Borrador
      </button>
      <button class="btn btn-primary" onclick="publishPost()">
        <i class="fa-solid fa-paper-plane"></i> Publicar
      </button>
    </div>
  </div>

  <div class="editor-grid">
    <!-- Main Content -->
    <div>
      <!-- Language Tabs -->
      <div class="lang-tabs">
        {langs.map((l, i) => (
          <button class:list={['lang-tab', { active: i === 0 }]} data-lang={l.code} onclick={`switchLang('${l.code}')`}>
            {l.label}
          </button>
        ))}
      </div>

      <!-- Translation Forms -->
      {langs.map((l, i) => (
        <div class:list={['tab-content', { active: i === 0 }]} id={`tab-${l.code}`}>
          <div class="form-group">
            <label>Título ({l.label})</label>
            <input type="text" class="form-input" id={`title-${l.code}`} placeholder={`Título del post en ${l.label}`} />
          </div>
          <div class="form-group">
            <label>Extracto ({l.label})</label>
            <textarea class="form-textarea" id={`excerpt-${l.code}`} placeholder={`Breve descripción en ${l.label}`} rows="3"></textarea>
          </div>
          <div class="form-group">
            <label>Contenido ({l.label})</label>
            <div class="editor-toolbar" id={`toolbar-${l.code}`}>
              <button type="button" class="toolbar-btn" onclick={`execCmd('${l.code}', 'bold')`} title="Negrita"><i class="fa-solid fa-bold"></i></button>
              <button type="button" class="toolbar-btn" onclick={`execCmd('${l.code}', 'italic')`} title="Itálica"><i class="fa-solid fa-italic"></i></button>
              <button type="button" class="toolbar-btn" onclick={`execCmd('${l.code}', 'underline')`} title="Subrayado"><i class="fa-solid fa-underline"></i></button>
              <button type="button" class="toolbar-btn" onclick={`execCmd('${l.code}', 'strikeThrough')`} title="Tachado"><i class="fa-solid fa-strikethrough"></i></button>
              <span class="toolbar-sep"></span>
              <button type="button" class="toolbar-btn" onclick={`execBlock('${l.code}', 'h2')`} title="Título H2"><b>H2</b></button>
              <button type="button" class="toolbar-btn" onclick={`execBlock('${l.code}', 'h3')`} title="Subtítulo H3"><b>H3</b></button>
              <button type="button" class="toolbar-btn" onclick={`execBlock('${l.code}', 'h4')`} title="Subtítulo H4"><b>H4</b></button>
              <button type="button" class="toolbar-btn" onclick={`execBlock('${l.code}', 'p')`} title="Párrafo"><i class="fa-solid fa-paragraph"></i></button>
              <span class="toolbar-sep"></span>
              <button type="button" class="toolbar-btn" onclick={`execCmd('${l.code}', 'insertUnorderedList')`} title="Lista"><i class="fa-solid fa-list-ul"></i></button>
              <button type="button" class="toolbar-btn" onclick={`execCmd('${l.code}', 'insertOrderedList')`} title="Lista Numerada"><i class="fa-solid fa-list-ol"></i></button>
              <span class="toolbar-sep"></span>
              <button type="button" class="toolbar-btn" onclick={`insertLink('${l.code}')`} title="Insertar Enlace"><i class="fa-solid fa-link"></i></button>
              <button type="button" class="toolbar-btn" onclick={`insertImage('${l.code}')`} title="Insertar Imagen"><i class="fa-solid fa-image"></i></button>
              <span class="toolbar-sep"></span>
              <button type="button" class="toolbar-btn" onclick={`execCmd('${l.code}', 'justifyLeft')`} title="Alinear Izquierda"><i class="fa-solid fa-align-left"></i></button>
              <button type="button" class="toolbar-btn" onclick={`execCmd('${l.code}', 'justifyCenter')`} title="Centrar"><i class="fa-solid fa-align-center"></i></button>
              <button type="button" class="toolbar-btn" onclick={`execCmd('${l.code}', 'justifyRight')`} title="Alinear Derecha"><i class="fa-solid fa-align-right"></i></button>
              <span class="toolbar-sep"></span>
              <button type="button" class="toolbar-btn" onclick={`insertBlockquote('${l.code}')`} title="Cita"><i class="fa-solid fa-quote-left"></i></button>
              <button type="button" class="toolbar-btn" onclick={`execCmd('${l.code}', 'removeFormat')`} title="Limpiar Formato"><i class="fa-solid fa-eraser"></i></button>
            </div>
            <div class="content-editor" id={`editor-${l.code}`} contenteditable="true" data-placeholder={`Escribe el contenido del blog en ${l.label}...`}></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Sidebar -->
    <div>
      <div class="stat-card" style="margin-bottom: 16px;">
        <div class="form-group">
          <label>Slug (URL)</label>
          <input type="text" class="form-input" id="post-slug" placeholder="mi-primer-post" />
          <small style="color: var(--text-color); font-size: 11px;">Solo minúsculas, números y guiones</small>
        </div>
      </div>

      <div class="stat-card" style="margin-bottom: 16px;">
        <div class="form-group">
          <label>Imagen de Portada</label>
          <div id="cover-preview" style="margin-bottom: 8px; display: none;">
            <img id="cover-img" style="width: 100%; border-radius: 8px;" />
          </div>
          <input type="file" id="cover-upload" accept="image/jpeg,image/png,image/webp,image/gif" style="display: none;" />
          <button class="btn btn-secondary btn-sm" style="width: 100%;" onclick="document.getElementById('cover-upload').click()">
            <i class="fa-solid fa-upload"></i> Subir Imagen
          </button>
        </div>
      </div>

      <div class="stat-card" style="margin-bottom: 16px;">
        <div class="form-group">
          <label>Categorías</label>
          {categories.map((cat) => {
            const catName = cat.translations.find(t => t.lang === 'es')?.name || cat.slug;
            return (
              <label style="display: flex; align-items: center; gap: 8px; margin-bottom: 6px; cursor: pointer; font-size: 14px;">
                <input type="checkbox" class="cat-checkbox" value={cat.id} />
                {catName}
              </label>
            );
          })}
        </div>
      </div>

      <div class="stat-card">
        <label style="color: var(--text-color); font-size: 13px; margin-bottom: 8px; display: block;">Auto-generar slug desde título</label>
        <button class="btn btn-secondary btn-sm" style="width: 100%;" onclick="generateSlug()">
          <i class="fa-solid fa-wand-magic-sparkles"></i> Generar Slug
        </button>
      </div>
    </div>
  </div>

  <!-- Hidden Image Upload for Editor -->
  <input type="file" id="editor-image-upload" accept="image/jpeg,image/png,image/webp,image/gif" style="display: none;" />

  <style>
    .editor-toolbar {
      display: flex;
      flex-wrap: wrap;
      gap: 2px;
      padding: 8px 12px;
      background: var(--accent-color-4, #0E0E0E);
      border: 1px solid var(--accent-color-3, #1F1F1F);
      border-bottom: none;
      border-radius: 12px 12px 0 0;
    }
    .toolbar-btn {
      background: none;
      border: 1px solid transparent;
      color: var(--text-color, #8B8B8B);
      padding: 6px 10px;
      cursor: pointer;
      border-radius: 6px;
      font-size: 13px;
      transition: all 0.3s;
      font-family: inherit;
    }
    .toolbar-btn:hover { background: var(--accent-color-3, #1F1F1F); color: var(--accent-color-2, #FFFFFF); }
    .toolbar-btn.active { background: var(--accent-color, #C82AEF); color: #fff; }
    .toolbar-sep { width: 1px; background: var(--accent-color-3, #1F1F1F); margin: 0 4px; }
    
    .content-editor {
      min-height: 400px;
      max-height: 600px;
      overflow-y: auto;
      padding: 20px;
      background: var(--secondary, #040404);
      border: 1px solid var(--accent-color-3, #1F1F1F);
      border-radius: 0 0 12px 12px;
      color: var(--primary, #D1D1D1);
      font-size: 15px;
      line-height: 1.7;
      outline: none;
      transition: border-color 0.3s;
    }
    .content-editor:focus {
      border-color: var(--accent-color, #C82AEF);
    }
    .content-editor:empty::before {
      content: attr(data-placeholder);
      color: var(--text-color, #8B8B8B);
    }
    .content-editor h2 { font-size: 24px; font-weight: 700; color: var(--accent-color-2, #FFFFFF); margin: 16px 0 8px; }
    .content-editor h3 { font-size: 20px; font-weight: 600; color: var(--accent-color-2, #FFFFFF); margin: 14px 0 6px; }
    .content-editor h4 { font-size: 18px; font-weight: 600; color: var(--primary, #D1D1D1); margin: 12px 0 6px; }
    .content-editor p { margin: 8px 0; }
    .content-editor ul, .content-editor ol { padding-left: 24px; margin: 8px 0; }
    .content-editor li { margin: 4px 0; }
    .content-editor a { color: var(--accent-color, #C82AEF); text-decoration: underline; }
    .content-editor img { max-width: 100%; border-radius: 12px; margin: 12px 0; }
    .content-editor blockquote {
      border-left: 3px solid var(--accent-color, #C82AEF);
      padding: 12px 16px;
      margin: 12px 0;
      background: rgba(200, 42, 239, 0.05);
      color: var(--text-color, #8B8B8B);
      font-style: italic;
      border-radius: 0 8px 8px 0;
    }
    @media (max-width: 768px) {
      .content-editor { min-height: 260px; padding: 14px; }
      .toolbar-sep { display: none; }
    }
    @media (max-width: 480px) {
      .content-editor { min-height: 200px; padding: 12px; font-size: 14px; }
      .editor-toolbar { padding: 6px 8px; gap: 1px; }
      .toolbar-btn { padding: 5px 7px; font-size: 12px; }
    }
  </style>

  <script is:inline>
    let coverImageUrl = '';
    let currentEditorLang = null;

    function switchLang(lang) {
      document.querySelectorAll('.lang-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
      document.querySelector('[data-lang="' + lang + '"]').classList.add('active');
      document.getElementById('tab-' + lang).classList.add('active');
    }

    function execCmd(lang, cmd, value) {
      document.getElementById('editor-' + lang).focus();
      document.execCommand(cmd, false, value || null);
    }

    function execBlock(lang, tag) {
      document.getElementById('editor-' + lang).focus();
      document.execCommand('formatBlock', false, '<' + tag + '>');
    }

    function insertLink(lang) {
      const url = prompt('URL del enlace:');
      if (!url) return;
      // Validate URL
      try { new URL(url); } catch { alert('URL inválida'); return; }
      const text = prompt('Texto del enlace (dejar vacío para usar la URL):');
      const editor = document.getElementById('editor-' + lang);
      editor.focus();
      
      const sel = window.getSelection();
      if (sel.rangeCount > 0 && sel.toString().length > 0) {
        document.execCommand('createLink', false, url);
      } else {
        const linkText = text || url;
        const a = document.createElement('a');
        a.href = url;
        a.textContent = linkText;
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
        
        const range = sel.getRangeAt(0);
        range.insertNode(a);
        range.setStartAfter(a);
        sel.removeAllRanges();
        sel.addRange(range);
      }
    }

    function insertImage(lang) {
      currentEditorLang = lang;
      document.getElementById('editor-image-upload').click();
    }

    function insertBlockquote(lang) {
      const editor = document.getElementById('editor-' + lang);
      editor.focus();
      document.execCommand('formatBlock', false, '<blockquote>');
    }

    // Editor image upload
    document.getElementById('editor-image-upload').addEventListener('change', async (e) => {
      const file = e.target.files[0];
      if (!file || !currentEditorLang) return;
      
      const formData = new FormData();
      formData.append('image', file);
      
      try {
        const res = await fetch('/api/blog/upload', { method: 'POST', body: formData });
        const data = await res.json();
        if (!res.ok) { showToast(data.error, 'error'); return; }
        
        const editor = document.getElementById('editor-' + currentEditorLang);
        editor.focus();
        const img = document.createElement('img');
        img.src = data.url;
        img.alt = 'Blog image';
        img.style.maxWidth = '100%';
        
        const sel = window.getSelection();
        if (sel.rangeCount > 0) {
          const range = sel.getRangeAt(0);
          range.insertNode(img);
          range.setStartAfter(img);
        } else {
          editor.appendChild(img);
        }
        showToast('Imagen insertada');
      } catch {
        showToast('Error al subir imagen', 'error');
      }
      e.target.value = '';
    });

    // Cover image upload
    document.getElementById('cover-upload').addEventListener('change', async (e) => {
      const file = e.target.files[0];
      if (!file) return;
      
      const formData = new FormData();
      formData.append('image', file);
      
      try {
        const res = await fetch('/api/blog/upload', { method: 'POST', body: formData });
        const data = await res.json();
        if (!res.ok) { showToast(data.error, 'error'); return; }
        
        coverImageUrl = data.url;
        document.getElementById('cover-img').src = data.url;
        document.getElementById('cover-preview').style.display = 'block';
        showToast('Imagen de portada cargada');
      } catch {
        showToast('Error al subir imagen', 'error');
      }
    });

    function generateSlug() {
      const title = document.getElementById('title-es').value || document.getElementById('title-en').value || '';
      const slug = title
        .toLowerCase()
        .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9\s-]/g, '')
        .replace(/\s+/g, '-')
        .replace(/-+/g, '-')
        .replace(/^-|-$/g, '');
      document.getElementById('post-slug').value = slug;
    }

    function getPostData(published) {
      const slug = document.getElementById('post-slug').value.trim();
      if (!slug) { showToast('El slug es requerido', 'error'); return null; }

      const langs = ['es', 'en', 'fr', 'pt'];
      const translations = [];
      
      for (const lang of langs) {
        const title = document.getElementById('title-' + lang).value.trim();
        const excerpt = document.getElementById('excerpt-' + lang).value.trim();
        const content = document.getElementById('editor-' + lang).innerHTML.trim();
        
        if (title || content) {
          translations.push({ lang, title, excerpt, content });
        }
      }

      if (translations.length === 0) {
        showToast('Escribe al menos un título y contenido', 'error');
        return null;
      }

      const categoryIds = Array.from(document.querySelectorAll('.cat-checkbox:checked')).map(cb => cb.value);

      return { slug, coverImage: coverImageUrl || null, published, translations, categoryIds };
    }

    async function saveDraft() {
      const data = getPostData(false);
      if (!data) return;
      try {
        await apiCall('/api/blog/posts', 'POST', data);
        showToast('Borrador guardado');
        setTimeout(() => window.location.href = '/admin/posts', 1000);
      } catch (e) { /* error handled */ }
    }

    async function publishPost() {
      const data = getPostData(true);
      if (!data) return;
      
      // Validate at least spanish version
      const esTranslation = data.translations.find(t => t.lang === 'es');
      if (!esTranslation || !esTranslation.title) {
        showToast('La versión en español es requerida para publicar', 'error');
        return;
      }

      try {
        await apiCall('/api/blog/posts', 'POST', data);
        showToast('¡Post publicado!');
        setTimeout(() => window.location.href = '/admin/posts', 1000);
      } catch (e) { /* error handled */ }
    }
  </script>
</AdminLayout>
